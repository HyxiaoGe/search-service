# Provider
SEARCH_PROVIDER=brave
BRAVE_API_KEY=your_key_here
TAVILY_API_KEY=

# Redis
REDIS_URL=redis://redis:6379

# Rate limits
RATE_LIMIT_GLOBAL=40/second
RATE_LIMIT_PER_IP=10/second

# Cache TTL (seconds)
CACHE_TTL_WEB=600
CACHE_TTL_NEWS=300
CACHE_TTL_IMAGE=1800

# Server
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
